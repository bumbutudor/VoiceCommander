# copiaza ca .env si completeaza valorile

# cheia gemini (optional - poti rula cu --no-ai)
GEMINI_API_KEY=your-gemini-api-key-here

# === Whisper ===

# default: small / ro
# WHISPER_MODEL=small
# WHISPER_LANGUAGE=ro

# backend STT: "faster" (faster-whisper, default) sau "cpp" (whisper.cpp Termux/ARM)
# WHISPER_BACKEND=faster

# pentru WHISPER_BACKEND=cpp:
# WHISPER_CPP_BIN=whisper-cli
# WHISPER_CPP_MODEL=~/whisper.cpp/models/ggml-tiny.bin
